const express = require('express');
const cors = require('cors');
const cookie = require('cookie');
const fs = require('fs/promises');
const path = require('path');
const crypto = require('crypto');
const multer = require('multer');
const axios = require('axios'); // 替换fetch，消除警告

const app = express();
app.use(cors());
app.use(express.json({ limit: '50mb' }));
app.use(express.urlencoded({ extended: true }));

// ==============================================
// 【安全防护：全局限流 + IP黑名单 + 后台白名单 + 错误捕获】
// 不改动任何业务逻辑，纯防护
// ==============================================
const rateLimit = require('express-rate-limit');

// 1. 全局限流：1 分钟最多 60 次请求（防CC攻击）
const globalLimiter = rateLimit({
  windowMs: 60 * 1000,
  max: 60,
  standardHeaders: true,
  message: { error: '请求过于频繁，请稍后再试' }
});

// 2. 登录接口限流：5 分钟最多 10 次（防暴力破解）
const loginLimiter = rateLimit({
  windowMs: 5 * 60 * 1000,
  max: 10,
  message: { error: '登录尝试过多，请5分钟后再试' }
});

// 应用全局限流
app.use(globalLimiter);

// 3. IP 黑名单（攻击你的 IP 填这里，一行一个）
const BLACKLIST_ENABLE = true; //启用黑名单过滤
const BLACKLIST_AUTO_ENABLE = true; // 自动黑名单 默认关闭false
const BLACKLIST_AUTO_TIME = 10 * 60 * 1000; // 自动封禁 10分钟
const IP_RECORD_LIMIT = 80; // 单IP 1分钟内超限则拉黑

// 手动黑名单
let BLACKLIST = [
  // 示例：
  // '1.2.3.4',
  // '5.6.7.8'
];

// 自动IP访问记录 + 封禁列表
const ipVisitMap = new Map();
const autoBlockMap = new Map();
const BLACKLIST_FILE = path.join(process.cwd(), 'blacklist.json');

// 加载本地黑名单
async function loadBlackList() {
  try {
    const txt = await fs.readFile(BLACKLIST_FILE, 'utf8');
    const arr = JSON.parse(txt);
    if(Array.isArray(arr)) BLACKLIST = arr;
  } catch {}
}
// 保存黑名单
async function saveBlackList() {
  await fs.writeFile(BLACKLIST_FILE, JSON.stringify(BLACKLIST,null,2),'utf8');
}
loadBlackList();

// 自动计数+自动封禁 定时清理
setInterval(() => {
  const now = Date.now();
  // 清理过期访问计数
  ipVisitMap.clear();
  // 解封过期IP
  for(const [ip, endTime] of autoBlockMap){
    if(now > endTime) autoBlockMap.delete(ip);
  }
}, 60 * 1000);

// IP拦截中间件（手动黑名单 + 自动黑名单）
app.use(async (req, res, next) => {
  const ip = getClientIp(req);
  const now = Date.now();
  
  // 实时读取最新黑名单（解封立刻生效）
  let realBlackList = [...BLACKLIST];
  try {
    const txt = await fs.readFile(BLACKLIST_FILE, 'utf8');
    const arr = JSON.parse(txt);
    if(Array.isArray(arr)) realBlackList = arr;
  } catch {}

  // 1. 自动封禁拦截
  if(BLACKLIST_AUTO_ENABLE && autoBlockMap.has(ip)){
    return res.status(403).end();
  }

  // 2. 手动黑名单拦截
  if(BLACKLIST_ENABLE && BLACKLIST.includes(ip)){
    return res.status(403).end();
  }

  // 3. 自动频率统计
  if(BLACKLIST_AUTO_ENABLE){
    const count = (ipVisitMap.get(ip) || 0) + 1;
    ipVisitMap.set(ip, count);

    // 超限自动拉黑
    if(count >= IP_RECORD_LIMIT){
      autoBlockMap.set(ip, now + BLACKLIST_AUTO_TIME);
      return res.status(403).end();
    }
  }

  next();
});

// 4. 日志后台 IP 白名单（只允许你自己访问 /logs，必填自己的公网IP）
const ADMIN_IP_WHITELIST_ENABLE = false;
const ADMIN_ALLOW_IPS = [
  '127.0.0.1',
  '::1',
  // 在这里填【你自己的公网IP】，示例：'111.222.333.444'
];
app.use('/logs', (req, res, next) => {
  // 开关关闭 => 直接放行
  if (!ADMIN_IP_WHITELIST_ENABLE) return next();
  
  const ip = getClientIp(req);
  if (!ADMIN_ALLOW_IPS.includes(ip)) {
    return res.status(403).send('Forbidden');
  }
  next();
});


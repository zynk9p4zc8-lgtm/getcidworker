  LOG_PASSWORD = newPwd;
}
initConfig();

// ====================== 百度 OCR 配置（无APP ID） ======================
const BAIDU_API_KEY = "OFClXkRRS9TRRTDvnKMk4TS1";
const BAIDU_SECRET_KEY = "cyWM6fnvKn5eeLAR6WBGZwYkU2OufuOJ";
//普通版 general_basic  高精度版accurate_basic
const ocrUrl = "https://aip.baidubce.com/rest/2.0/ocr/v1/general_basic";

if (!BAIDU_API_KEY || !BAIDU_SECRET_KEY) {
  console.error('❌ 错误：百度OCR授权信息未配置！');
  process.exit(1);
